# ============================================================================
# .gitignore — Socratic AI Tutor
# ============================================================================

# ---------- Large AI Models ----------
*.gguf
*.bin
backend/models/
socratic_app/assets/models/

# ---------- llama.cpp source (compiled from source via CMake) ----------
local_llama_cpp_dart/

# ---------- Python ----------
.venv/
**/__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.eggs/
backend/evaluation/logs/*.json

# ---------- Flutter / Dart ----------
socratic_app/build/
socratic_app/.flutter-plugins
socratic_app/.flutter-plugins-dependencies
socratic_app/.packages
socratic_app/.pub-cache/
socratic_app/.dart_tool/
socratic_app/generated/

# ---------- Web App (not part of mobile submission) ----------
webapp/
webapp/node_modules/
webapp/dist/

# ---------- Build artifacts ----------
build/
dist/
*.log

# ---------- IDEs and OS ----------
.idea/
.vscode/
*.iml
.DS_Store
.env

# ---------- Figma / Graphics ----------
*.fig

# ---------- Development & Training (not for submission) ----------
notebooks/
research.txt
*.lock

# ---------- Test Screenshots (optional - kept for reference) ----------
# testing/emulator/screenshots/*.png
# testing/huawei*/screenshots/*.png
# testing/samsung*/screenshots/*.png
